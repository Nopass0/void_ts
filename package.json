{
  "name": "@voiddb/orm",
  "version": "1.1.0",
  "description": "Official TypeScript ORM for VoidDB – type-safe document store client",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "generate": "npm run build && node scripts/cli.mjs generate",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "voiddb-orm": "scripts/cli.mjs",
    "voiddb-generate": "scripts/cli.mjs",
    "voiddb-schema": "scripts/cli.mjs",
    "voiddb-migrate": "scripts/cli.mjs"
  },
  "files": [
    "dist",
    "scripts/cli.mjs",
    "scripts/generate.mjs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "voiddb",
    "database",
    "orm",
    "nosql",
    "document-store",
    "typescript"
  ],
  "author": "VoidDB Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nopass0/void_ts.git"
  },
  "homepage": "https://nopass0.github.io/void_ts/",
  "bugs": {
    "url": "https://github.com/Nopass0/void_ts/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "axios": "^1.7.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "typescript": ">=4.7"
  },
  "engines": {
    "node": ">=16"
  }
}
